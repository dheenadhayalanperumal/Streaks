# Copy to .env and adjust
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=streaks
DB_USER=root
DB_PASS=

# CORS origin for the Next.js admin
CORS_ORIGIN=http://localhost:3000

# Seed admin (created by seed.php)
ADMIN_EMAIL=admin@streaks.test
ADMIN_PASSWORD=admin123

# WhatsApp Business Cloud API. Leave ACCESS_TOKEN / PHONE_NUMBER_ID blank to run
# in SIMULATION mode (messages are logged to the server console, never sent).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_TEMPLATE_LANG=en_US
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_VERIFY_TOKEN=streaks-verify
